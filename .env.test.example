# Copy this file to .env.test and fill in real values.
# Used only when building for E2E: `vite build --mode test`.
# Vite bakes VITE_* vars in at build time, so E2E must use its own
# .env.test rather than whatever .env happens to be present locally —
# otherwise a local E2E run risks silently building against production.
#
# Point these at your local Supabase stack (from `supabase start`) and
# Cloudflare's official "always passes" dummy Turnstile sitekey, not
# real production values.
# .env.test is gitignored — never commit actual secrets.

VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=
VITE_STADIA_MAPS_API_KEY=
VITE_ANALYTICS_DOMAIN=
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA