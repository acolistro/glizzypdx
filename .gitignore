cat > .gitignore << 'EOF'
# Dependencies
node_modules/

# Build output
dist/
dist-ssr/
build/

# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Testing
coverage/
playwright-report/
test-results/
blob-report/

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite
*.local

# TypeScript
*.tsbuildinfo

# Supabase local dev
supabase/.branches
supabase/.temp
EOF