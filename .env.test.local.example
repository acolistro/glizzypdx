# .env.test.local.example
#
# Copy to `.env.test.local` (gitignored) and fill in values from your running local
# Supabase stack. Powers the Vitest INTEGRATION harness (GLPDX-162).
#
# NOT `VITE_`-prefixed on purpose: Vite inlines VITE_* into the browser bundle, and the
# service_role key must never be exposed that way.
#
# Populate after `supabase start`:
#   supabase status -o json | grep -i "API_URL\|ANON_KEY\|SERVICE_ROLE"

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=<local anon key from `supabase status -o json`>
SUPABASE_SERVICE_ROLE_KEY=<local service_role key from `supabase status -o json`>